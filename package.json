{
  "name": "djs-next",
  "version": "1.0.0",
  "description": "A framework package for discord.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "djs-next": "./bin/create-djs-next.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "test": "node node_modules/vitest/vitest.mjs run"
  },
  "keywords": [
    "discord.js",
    "framework",
    "bot",
    "djs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chokidar": "^5.0.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
